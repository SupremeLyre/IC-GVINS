<launch>
    <arg name="configfile" default="$(find-pkg-share ic_gvins)/config/gvins.yaml"/>

    <node name="ic_gvins_node" pkg="ic_gvins" exec="ic_gvins_ros" output="screen">
        <param name="imu_topic" value="/imu0"/>
        <param name="gnss_topic" value="/gnss0"/>
        <param name="image_topic" value="/cam0"/>

        <param name="configfile" value="$(var configfile)"/>
    </node>

    <node pkg="tf2_ros" exec="static_transform_publisher" name="world_to_map_broadcaster"
          args="--x 0 --y 0 --z 0 --qx -1 --qy 0 --qz 0 --qw 0 --frame-id map --child-frame-id world"/>
    <node name="visualisation" pkg="rviz2" exec="rviz2" output="log"
          args="-d $(find-pkg-share ic_gvins)/config/visualization.rviz"/>
</launch>
